{
  "name": "mitch-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "src/apps/*",
    "src/packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:pnpm": "pnpm -r --filter ./src/packages/* build",
    "build:topo": "pnpm -r --filter ./src/packages/* --sort build",
    "build:all": "pnpm -r --filter ./src/packages/* build && pnpm -r --filter ./src/apps/* build",
    "dev:wallet": "pnpm --filter @mitch/wallet-pwa dev",
    "dev:issuer": "pnpm --filter @mitch/issuer-mock dev",
    "dev:verifier": "pnpm --filter verifier-backend dev",
    "demo": "bash dev-demo.sh",
    "demo:win": "powershell -ExecutionPolicy Bypass -File dev-demo.ps1",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "turbo run test",
    "test:golden": "pnpm --filter @mitch/integration-tests exec vitest run src/fail-closed-golden.test.ts",
    "clean": "turbo run clean",
    "clean:pnpm": "pnpm -r --filter ./src/packages/* clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "eslint": "^9.21.0",
    "playwright": "^1.58.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.0",
    "turbo": "^1.13.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.25.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "ajv": ">=6.14.0",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "esbuild@<=0.24.2": ">=0.25.0"
    }
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1"
  }
}