# ============================================================
#  miTch — .gitignore
#  Regel: So spezifisch wie nötig, so breit wie sinnvoll.
#  Niemals Quellcode-Ordner mit generischen Namen ignorieren.
# ============================================================

# ── Node / Package Manager ──────────────────────────────────
node_modules/
.pnpm-store/

# ── Build-Artefakte ─────────────────────────────────────────
dist/
build/
out/
coverage/
*.tsbuildinfo

# ── Turbo / Caches ──────────────────────────────────────────
.turbo/
.logs/
.vite/
.cache/

# ── Umgebung / Secrets ──────────────────────────────────────
.env
.env.*
!.env.example
!.env.strict.example

# ── Runtime-Artefakte (generiert, nicht committen) ──────────
src/apps/verifier-demo/backend/verifier-key.json
src/apps/verifier-demo/backend/nonce-cache.json

# ── Editor / OS ─────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.local

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── Test-Output ─────────────────────────────────────────────
test-results/
playwright-report/
blob-report/

# ── Temporäre Dateien ───────────────────────────────────────
*.tmp
*.bak
*.swp
# Editor-crash lockfile artifacts (e.g. pnpm-lock.yaml.1184410667)
pnpm-lock.yaml.*[0-9]
# Binary context packs — never commit
*.zip

# ── EXPLIZIT NICHT IGNORIEREN ───────────────────────────────
# src/**/data/   ← Quellcode! (DemoPolicy.ts, Seed-Credentials)
# docs/          ← Dokumentation
# archive/       ← Git-Bundles
.claude/
