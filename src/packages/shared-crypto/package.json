{
    "name": "@mitch/shared-crypto",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "clean": "rimraf dist",
        "dev": "tsx watch src/index.ts",
        "build": "tsc -p tsconfig.build.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "tsc --noEmit",
        "format": "prettier --write \"src/**/*.ts\""
    },
    "dependencies": {
        "@mitch/shared-types": "workspace:*",
        "@noble/curves": "^2.0.1",
        "@noble/hashes": "^2.0.1",
        "@noble/post-quantum": "^0.5.4",
        "jose": "^5.2.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "prettier": "^3.0.0",
        "rimraf": "^5.0.0",
        "typescript": "^5.2.0",
        "vitest": "^2.1.9"
    }
}
